DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DJANGO_DEBUG=True

# PostgreSQL
POSTGRES_DB=crm_obra_social
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Evolution API (WhatsApp via QR — sin API oficial de Meta)
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=tu_api_key_segura
EVOLUTION_INSTANCE_NAME=crm-supreg
EVOLUTION_WEBHOOK_TOKEN=token_secreto_para_validar_webhooks
EVOLUTION_SERVER_URL=http://localhost:8080

# Proxy residencial (opcional — necesario si el VPS tiene IP de datacenter bloqueada por WhatsApp)
PROXY_HOST=
PROXY_PORT=
PROXY_PROTOCOL=http
PROXY_USERNAME=
PROXY_PASSWORD=

ALLOWED_HOSTS=localhost 127.0.0.1 your-domain.com

# n8n integration (dejar vacío para deshabilitar)
N8N_WEBHOOK_URL=https://n8n.tudominio.com/webhook/whatsapp
N8N_ENCENDER_BOT_URL=https://n8n.tudominio.com/webhook/encender_bot
CRM_API_KEY=clave-secreta-para-que-n8n-envie-mensajes
